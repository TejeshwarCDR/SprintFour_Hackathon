{
  "name": "conseal-backend",
  "version": "1.0.0",
  "description": "Conseal document redaction review backend",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "check:schema": "node scripts/check-schema.js",
    "diagnose:nim": "node scripts/diagnose-nim.js",
    "dev": "node --watch src/server.js",
    "integration:e2e": "node scripts/run-e2e.js",
    "integration:e2e:live": "node scripts/run-e2e.js --use-mock-llm=false --strict-reconciliation=false",
    "integration:e2e:mock": "node scripts/run-e2e.js --use-mock-llm=true --strict-reconciliation=true",
    "start": "node src/server.js",
    "test": "node --test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.71.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {}
}
